#!/usr/bin/env python3
"""Report: ACV movement through pipeline stages for a given date range.

Outputs a self-contained HTML chart and a CSV in reports/stage_flow/.
Uses the portfolio view from views.yaml (team + include_ninjas + deal_types).

Date inputs accept any of:
  2026-03-15        specific date
  2026-03           month  (start → 1st, end → last day)
  Q1 2026           quarter (start → first day Q, end → last day Q)
  Jan 2026          month name
"""

import argparse
import calendar
import csv
import json
import os
import re
import sys
from collections import defaultdict
from datetime import datetime

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import sfq
from constants import CHATTER_BATCH_SIZE
from shared import (
    OPP_CACHE_FILE, DEFAULT_MANAGER_ID, DEAL_TYPES,
    GREEN, RESET, DIM, BOLD, YELLOW,
    enrich, load_views, apply_filters,
)

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
OUTPUT_DIR = os.path.join(SCRIPT_DIR, "reports", "stage_flow")

TARGET_STAGES = [
    "1. Qualified Prospect",
    "2. Value Scenario",
    "3. Value Proposal",
    "4. Closing",
    "5. Won",
]

STAGE_LABELS = {
    "1. Qualified Prospect": "Stage 1 – Qualified Prospect",
    "2. Value Scenario":     "Stage 2 – Value Scenario",
    "3. Value Proposal":     "Stage 3 – Value Proposal",
    "4. Closing":            "Stage 4 – Closing",
    "5. Won":                "Stage 5 – Won",
}

STAGE_COLORS = [
    "#4e79a7",   # blue   – stage 1
    "#f28e2b",   # orange – stage 2
    "#59a14f",   # green  – stage 3
    "#e15759",   # red    – stage 4
    "#76b7b2",   # teal   – stage 5 won
]

QUARTER_MONTHS = {1: (1, 3), 2: (4, 6), 3: (7, 9), 4: (10, 12)}


# ---------------------------------------------------------------------------
# Date parsing
# ---------------------------------------------------------------------------

def parse_date_input(value, as_end=False):
    """Parse flexible date input to YYYY-MM-DD string.

    as_end=True  → last day of the period (for --to)
    as_end=False → first day of the period (for --from)
    """
    value = value.strip()

    # YYYY-MM-DD
    try:
        datetime.strptime(value, "%Y-%m-%d")
        return value
    except ValueError:
        pass

    # Quarter: Q1 2026, Q1-2026, Q12026, 2026-Q1, 2026Q1
    qm = re.match(
        r'(?:Q(\d)[^0-9]*(\d{4})|(\d{4})[^0-9]*Q(\d))',
        value, re.IGNORECASE,
    )
    if qm:
        g = qm.groups()
        q, year = (int(g[0]), int(g[1])) if g[0] else (int(g[3]), int(g[2]))
        if q not in QUARTER_MONTHS:
            raise ValueError(f"Invalid quarter Q{q} in '{value}'")
        start_m, end_m = QUARTER_MONTHS[q]
        if as_end:
            return f"{year}-{end_m:02d}-{calendar.monthrange(year, end_m)[1]:02d}"
        return f"{year}-{start_m:02d}-01"

    # YYYY-MM
    try:
        dt = datetime.strptime(value, "%Y-%m")
        if as_end:
            return f"{dt.year}-{dt.month:02d}-{calendar.monthrange(dt.year, dt.month)[1]:02d}"
        return f"{dt.year}-{dt.month:02d}-01"
    except ValueError:
        pass

    # "Jan 2026", "January 2026", "Jan-2026"
    for fmt in ("%b %Y", "%B %Y", "%b-%Y", "%B-%Y", "%b%Y", "%B%Y"):
        try:
            dt = datetime.strptime(value, fmt)
            if as_end:
                return f"{dt.year}-{dt.month:02d}-{calendar.monthrange(dt.year, dt.month)[1]:02d}"
            return f"{dt.year}-{dt.month:02d}-01"
        except ValueError:
            pass

    raise ValueError(
        f"Cannot parse '{value}'. Use: 2026-03-15, 2026-03, Q1 2026, or Jan 2026"
    )


def friendly_date(date_str):
    """'2026-01-01' → 'Jan 1, 2026'"""
    return datetime.strptime(date_str, "%Y-%m-%d").strftime("%b %-d, %Y")


# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def stage_order(name):
    if not name:
        return -1
    try:
        return int(str(name).split(".")[0])
    except (ValueError, AttributeError):
        return -1


def matches_stage(new_value, target_stage):
    t_order = stage_order(target_stage)
    e_order = stage_order(new_value or "")
    if t_order == 5:
        return e_order == 5 or "won" in (new_value or "").lower()
    return e_order == t_order


def effective_order(record):
    is_closed = record.get("IsClosed", False)
    stage     = record.get("StageName", "") or ""
    order     = stage_order(stage)
    if is_closed:
        if order == 5 or "won" in stage.lower():
            return 5
        return -1   # Lost — excluded
    return order


def months_in_range(start_date_str, end_date_str):
    start  = datetime.strptime(start_date_str[:7], "%Y-%m")
    end    = datetime.strptime(end_date_str[:7],   "%Y-%m")
    months, y, m = [], start.year, start.month
    while (y, m) <= (end.year, end.month):
        months.append(f"{y}-{m:02d}")
        m += 1
        if m > 12:
            m, y = 1, y + 1
    return months


def month_label(ym):
    return datetime.strptime(ym, "%Y-%m").strftime("%b %Y")


# ---------------------------------------------------------------------------
# Salesforce fetch
# ---------------------------------------------------------------------------

def load_portfolio_records():
    if not os.path.exists(OPP_CACHE_FILE):
        print("  No cache found. Run: salesfx --refresh")
        sys.exit(1)

    with open(OPP_CACHE_FILE) as f:
        cache_data = json.load(f)
    fetched_at  = cache_data.get("fetched_at", "unknown")
    all_records = cache_data["records"]

    views = load_views()
    view  = views.get("portfolio", {})
    territory = view.get("territory")
    filter_args = argparse.Namespace(
        account=None, ae=None, ninja=None, type=None, all_stages=True,
        team=DEFAULT_MANAGER_ID if view.get("team") else None,
        quarter=None, stage=None,
        territory=([territory] if isinstance(territory, str) else territory),
    )
    records = apply_filters(all_records, filter_args)

    include_ninjas = view.get("include_ninjas", [])
    if include_ninjas:
        seen_ids = {r["Id"] for r in records}
        no_team_vars = {**vars(filter_args), "team": None}
        pool = apply_filters(all_records, argparse.Namespace(**no_team_vars))
        for name in include_ninjas:
            q = name.lower()
            for r in pool:
                if r["Id"] not in seen_ids and q in (r.get("Solution_Strategist1__r.Name", "") or "").lower():
                    records.append(r)
                    seen_ids.add(r["Id"])

    if DEAL_TYPES:
        records = [r for r in records if r.get("Type", "") in DEAL_TYPES]

    records = enrich(records)
    return records, fetched_at


def fetch_stage_history(opp_ids, start_date, end_date):
    all_history = []
    for i in range(0, len(opp_ids), CHATTER_BATCH_SIZE):
        chunk   = opp_ids[i:i + CHATTER_BATCH_SIZE]
        ids_str = ", ".join(f"'{oid}'" for oid in chunk)
        query   = (
            "SELECT OpportunityId, OldValue, NewValue, CreatedDate "
            "FROM OpportunityFieldHistory "
            f"WHERE Field = 'StageName' "
            f"AND OpportunityId IN ({ids_str}) "
            f"AND CreatedDate >= {start_date}T00:00:00Z "
            f"AND CreatedDate <= {end_date}T23:59:59Z "
            "ORDER BY OpportunityId, CreatedDate ASC"
        )
        all_history.extend(sfq.sf_query(query))
    return all_history


# ---------------------------------------------------------------------------
# Processing
# ---------------------------------------------------------------------------

def build_flow_data(records, history):
    """Apply regression + re-entry rules and aggregate into monthly buckets.

    Each entry: (acv, opp_name, account, in_window)
    in_window=False → opp entered this stage in the period but its prior-stage
                      movement was before the period or it skipped that stage.
    """
    opp_lookup     = {r["Id"]: r for r in records}
    history_by_opp = defaultdict(list)
    for entry in history:
        oid = entry.get("OpportunityId", "")
        if oid:
            history_by_opp[oid].append(entry)

    data = defaultdict(list)

    for opp_id, entries in history_by_opp.items():
        r = opp_lookup.get(opp_id)
        if not r:
            continue

        eff_order = effective_order(r)
        if eff_order < 1:
            continue

        acv     = r.get("_acv", 0) or 0
        name    = r.get("Name", "")
        account = r.get("Account.Name", "")

        stages_in_window = {stage_order(e.get("NewValue", "")) for e in entries}
        if any("won" in (e.get("NewValue") or "").lower() for e in entries):
            stages_in_window.add(5)

        for stage in TARGET_STAGES:
            s_order = stage_order(stage)
            if eff_order < s_order:
                continue

            entries_for_stage = [
                e for e in entries if matches_stage(e.get("NewValue", ""), stage)
            ]
            if not entries_for_stage:
                continue

            entries_for_stage.sort(key=lambda e: e.get("CreatedDate", ""), reverse=True)
            ym = entries_for_stage[0].get("CreatedDate", "")[:7]
            if not ym:
                continue

            in_window = True if s_order <= 1 else (s_order - 1) in stages_in_window
            data[(ym, stage)].append((acv, name, account, in_window))

    return data


# ---------------------------------------------------------------------------
# HTML output
# ---------------------------------------------------------------------------

def build_html(data, months, fetched_at, start_date, end_date):
    stage_totals = {}
    stage_counts = {}
    prior_totals = {}
    prior_counts = {}
    for stage in TARGET_STAGES:
        all_entries          = [e for ym in months for e in data.get((ym, stage), [])]
        stage_totals[stage]  = sum(e[0] for e in all_entries)
        stage_counts[stage]  = len(all_entries)
        prior_totals[stage]  = sum(e[0] for e in all_entries if not e[3])
        prior_counts[stage]  = sum(1     for e in all_entries if not e[3])

    # ---- deal data for drill-down (sorted by ACV desc) ----
    stage_deals = {}
    for stage in TARGET_STAGES:
        deals = []
        for ym in months:
            for acv, name, account, in_window in data.get((ym, stage), []):
                deals.append({
                    "name": name, "account": account,
                    "acv": round(acv), "month": month_label(ym),
                    "inWindow": in_window,
                })
        deals.sort(key=lambda d: d["acv"], reverse=True)
        stage_deals[STAGE_LABELS[stage]] = deals
    stage_deals_js = json.dumps(stage_deals)

    def conv(a, b, use_count=False):
        num = stage_counts[b] if use_count else stage_totals[b]
        den = stage_counts[a] if use_count else stage_totals[a]
        return round(num / den * 100, 1) if den else 0

    datasets = []
    for i, stage in enumerate(TARGET_STAGES):
        datasets.append({
            "label":           STAGE_LABELS[stage],
            "data":            [round(sum(e[0] for e in data.get((ym, stage), []))) for ym in months],
            "backgroundColor": STAGE_COLORS[i],
            "borderRadius":    4,
        })

    labels_js   = json.dumps([month_label(m) for m in months])
    datasets_js = json.dumps(datasets)
    today_str   = datetime.now().strftime("%B %-d, %Y")
    max_acv     = stage_totals[TARGET_STAGES[0]] or 1
    from_label  = friendly_date(start_date)
    to_label    = friendly_date(end_date)

    funnel_rows = ""
    for i, stage in enumerate(TARGET_STAGES):
        acv     = stage_totals[stage]
        count   = stage_counts[stage]
        p_acv   = prior_totals[stage]
        p_count = prior_counts[stage]
        color   = STAGE_COLORS[i]
        in_w    = acv - p_acv
        label   = STAGE_LABELS[stage]
        label_js = json.dumps(label)

        bar_main  = round(in_w  / max_acv * 100)
        bar_prior = round(p_acv / max_acv * 100)

        prior_note = ""
        if p_count > 0:
            prior_note = (
                f'<div class="prior-note">⚠ {p_count} deal{"s" if p_count > 1 else ""} '
                f'(€{p_acv:,.0f}) entered this stage with no prior-stage movement '
                f'recorded in the selected period</div>'
            )

        if i < len(TARGET_STAGES) - 1:
            ns    = TARGET_STAGES[i + 1]
            arrow = (f'<div class="arrow">↓ &nbsp;{conv(stage, ns)}% ACV'
                     f' &nbsp;·&nbsp; {conv(stage, ns, use_count=True)}% deals</div>')
        else:
            s1    = TARGET_STAGES[0]
            arrow = (f'<div class="arrow overall">S1 → Won: &nbsp;{conv(s1, stage)}% ACV'
                     f' &nbsp;·&nbsp; {conv(s1, stage, use_count=True)}% deals</div>')

        funnel_rows += f"""
        <div class="funnel-stage clickable" onclick="togglePanel({label_js})" id="row-{i}">
          <div class="funnel-label">{label}</div>
          <div class="funnel-track">
            <div class="funnel-bar-wrap">
              <div class="funnel-bar" style="width:{bar_main}%;background:{color}"></div>
              <div class="funnel-bar prior" style="width:{bar_prior}%;background:{color}"></div>
            </div>
            <span class="funnel-stat">€{acv:,.0f} &nbsp;·&nbsp; {count} deals</span>
          </div>
          <span class="toggle-icon" id="icon-{i}">▶</span>
        </div>
        <div class="deal-panel" id="panel-{i}"></div>
        {prior_note}
        {arrow}"""

    legend = (
        '<div class="legend">'
        '<span class="leg-swatch solid"></span> Fully tracked within period &nbsp;&nbsp;'
        '<span class="leg-swatch prior"></span> Prior period / stage skipped'
        '</div>'
    )

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pipeline Stage Flow</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  body {{ font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
         background: #f8f9fa; color: #212529; margin: 0; padding: 24px; }}
  h1   {{ font-size: 1.4rem; margin-bottom: 4px; }}
  .sub {{ color: #6c757d; font-size: 0.9rem; margin-bottom: 32px; }}
  .card {{ background: #fff; border-radius: 8px; padding: 24px;
           box-shadow: 0 1px 4px rgba(0,0,0,.08); margin-bottom: 24px; }}
  .card h2 {{ font-size: 1rem; margin: 0 0 20px; color: #495057; }}
  .funnel-stage   {{ display: flex; align-items: center; gap: 12px; margin-bottom: 4px;
                     border-radius: 6px; padding: 2px 4px; }}
  .funnel-stage.clickable {{ cursor: pointer; }}
  .funnel-stage.clickable:hover {{ background: #f8f9fa; }}
  .funnel-label   {{ width: 210px; font-size: 0.85rem; color: #495057; flex-shrink: 0; }}
  .funnel-track   {{ flex: 1; display: flex; align-items: center; gap: 8px; }}
  .funnel-bar-wrap {{ flex: 1; background: #f1f3f5; border-radius: 4px; height: 34px;
                      display: flex; overflow: hidden; }}
  .funnel-bar      {{ height: 100%; flex-shrink: 0; }}
  .funnel-bar.prior {{ opacity: 0.35; }}
  .funnel-stat    {{ font-size: 0.82rem; color: #495057; white-space: nowrap;
                     font-weight: 600; min-width: 180px; }}
  .toggle-icon    {{ font-size: 0.7rem; color: #adb5bd; flex-shrink: 0; width: 14px; }}
  .prior-note     {{ margin: 1px 0 4px 222px; font-size: 0.78rem; color: #e67700; }}
  .arrow          {{ margin: 2px 0 6px 222px; font-size: 0.82rem; color: #868e96; }}
  .overall        {{ color: #212529; font-weight: 600; margin-top: 4px; }}
  .legend         {{ margin-top: 20px; font-size: 0.8rem; color: #868e96;
                     display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }}
  .leg-swatch     {{ display: inline-block; width: 14px; height: 14px;
                     border-radius: 2px; background: #4e79a7; }}
  .leg-swatch.prior {{ opacity: 0.35; }}

  /* deal panel */
  .deal-panel     {{ display: none; margin: 0 0 8px 4px; overflow: hidden; }}
  .deal-panel table {{ width: 100%; border-collapse: collapse; font-size: 0.82rem; }}
  .deal-panel th  {{ background: #f8f9fa; font-weight: 600; padding: 6px 10px;
                     text-align: left; border-bottom: 1px solid #e9ecef; color: #6c757d; }}
  .deal-panel td  {{ padding: 6px 10px; border-bottom: 1px solid #f1f3f5; }}
  .deal-panel tr:last-child td {{ border-bottom: none; }}
  .deal-panel tr:hover td {{ background: #f8f9fa; }}
  .deal-panel .acv {{ text-align: right; font-variant-numeric: tabular-nums; }}
  .deal-panel .warn {{ color: #e67700; font-size: 0.75rem; }}
</style>
</head>
<body>
<h1>Pipeline Stage Flow</h1>
<p class="sub">{from_label} → {to_label} &nbsp;·&nbsp; Cache from {fetched_at}
&nbsp;·&nbsp; Generated {today_str}</p>

<div class="card">
  <h2>Conversion Funnel &nbsp;<span style="font-size:0.8rem;font-weight:400;color:#adb5bd">click a stage to see deals</span></h2>
  {funnel_rows}
  {legend}
</div>

<div class="card">
  <h2>Monthly Activity</h2>
  <canvas id="chart" height="90"></canvas>
</div>

<script>
const stageDeals = {stage_deals_js};
const openPanels = {{}};

function togglePanel(label) {{
  const idx = {json.dumps([STAGE_LABELS[s] for s in TARGET_STAGES])}.indexOf(label);
  if (idx === -1) return;
  const panel = document.getElementById('panel-' + idx);
  const icon  = document.getElementById('icon-'  + idx);
  if (openPanels[label]) {{
    panel.style.display = 'none';
    icon.textContent = '▶';
    delete openPanels[label];
    return;
  }}
  openPanels[label] = true;
  icon.textContent = '▼';
  const deals = stageDeals[label] || [];
  if (!deals.length) {{
    panel.innerHTML = '<div style="padding:8px 4px;color:#adb5bd;font-size:0.82rem">No deals in this stage for the selected period.</div>';
  }} else {{
    const rows = deals.map(d =>
      `<tr>
        <td>${{d.account}}</td>
        <td>${{d.name}}</td>
        <td class="acv">€${{d.acv.toLocaleString()}}</td>
        <td>${{d.month}}</td>
        <td>${{d.inWindow ? '' : '<span class="warn">⚠ prior period</span>'}}</td>
      </tr>`
    ).join('');
    panel.innerHTML = `<table>
      <thead><tr><th>Account</th><th>Opportunity</th><th style="text-align:right">ACV</th><th>Month</th><th></th></tr></thead>
      <tbody>${{rows}}</tbody>
    </table>`;
  }}
  panel.style.display = 'block';
}}

new Chart(document.getElementById('chart'), {{
  type: 'bar',
  data: {{
    labels: {labels_js},
    datasets: {datasets_js}
  }},
  options: {{
    responsive: true,
    plugins: {{
      legend: {{ position: 'top' }},
      tooltip: {{
        callbacks: {{
          label: ctx => ' ' + ctx.dataset.label + ':  €' +
                 ctx.parsed.y.toLocaleString('en-EU')
        }}
      }}
    }},
    scales: {{
      x: {{ grid: {{ display: false }} }},
      y: {{
        ticks: {{
          callback: v => '€' + (v >= 1e6 ? (v/1e6).toFixed(1)+'M'
                                         : (v/1e3).toFixed(0)+'K')
        }},
        grid: {{ color: '#f1f3f5' }}
      }}
    }}
  }}
}});
</script>
</body>
</html>"""


# ---------------------------------------------------------------------------
# CSV output
# ---------------------------------------------------------------------------

def write_csv(data, months, path):
    with open(path, "w", newline="", encoding="utf-8") as f:
        writer = csv.writer(f)
        writer.writerow([
            "Month", "Stage", "ACV (EUR)", "Opp Count",
            "Prior Period Count", "Opportunities",
        ])
        for ym in months:
            for stage in TARGET_STAGES:
                entries = data.get((ym, stage), [])
                if not entries:
                    continue
                writer.writerow([
                    month_label(ym),
                    STAGE_LABELS[stage],
                    round(sum(e[0] for e in entries)),
                    len(entries),
                    sum(1 for e in entries if not e[3]),
                    "; ".join(f"{e[1]}{' *' if not e[3] else ''}" for e in entries),
                ])


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        description="ACV stage flow report",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "Date formats accepted:\n"
            "  2026-03-15    specific date\n"
            "  2026-03       month\n"
            "  Q1 2026       quarter\n"
            "  Jan 2026      month name\n"
        ),
    )
    parser.add_argument("--from", dest="date_from", default=None, metavar="DATE",
                        help="Start of period (default: Jan 1 this year)")
    parser.add_argument("--to",   dest="date_to",   default=None, metavar="DATE",
                        help="End of period (default: today)")
    parser.add_argument("--refresh", action="store_true",
                        help="Re-fetch opportunity data from Salesforce first")
    args = parser.parse_args()

    try:
        start_date = (parse_date_input(args.date_from)
                      if args.date_from
                      else f"{datetime.now().year}-01-01")
        end_date   = (parse_date_input(args.date_to, as_end=True)
                      if args.date_to
                      else datetime.now().strftime("%Y-%m-%d"))
    except ValueError as e:
        print(f"  Error: {e}")
        sys.exit(1)

    if start_date > end_date:
        print(f"  Error: --from ({start_date}) is after --to ({end_date})")
        sys.exit(1)

    if args.refresh:
        print(f"\n  {BOLD}{YELLOW}Refreshing opportunity cache...{RESET}")
        import subprocess
        subprocess.run([sys.executable, os.path.join(SCRIPT_DIR, "salesfx"), "--refresh"],
                       check=True)

    print(f"\n  {DIM}Period: {friendly_date(start_date)} → {friendly_date(end_date)}{RESET}")
    print(f"  {DIM}Loading portfolio...{RESET}")
    records, fetched_at = load_portfolio_records()
    opp_ids = [r["Id"] for r in records if r.get("Id")]
    print(f"  {len(opp_ids)} opportunities in scope")

    print(f"  {DIM}Fetching stage history from Salesforce...{RESET}")
    history = fetch_stage_history(opp_ids, start_date, end_date)
    print(f"  {len(history)} stage change events fetched")

    months = months_in_range(start_date, end_date)
    data   = build_flow_data(records, history)

    os.makedirs(OUTPUT_DIR, exist_ok=True)
    stamp    = datetime.now().strftime("%Y%m%d_%H%M")
    html_out = os.path.join(OUTPUT_DIR, f"stage_flow_{stamp}.html")
    csv_out  = os.path.join(OUTPUT_DIR, f"stage_flow_{stamp}.csv")

    with open(html_out, "w", encoding="utf-8") as f:
        f.write(build_html(data, months, fetched_at, start_date, end_date))

    write_csv(data, months, csv_out)

    total_acv = sum(sum(e[0] for e in v) for v in data.values())
    print(f"\n  {GREEN}Done{RESET}")
    print(f"  Total ACV in motion: €{total_acv:,.0f}")
    print(f"  HTML → {html_out}")
    print(f"  CSV  → {csv_out}")
