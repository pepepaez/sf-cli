#!/usr/bin/env python3
"""Initial setup for sf-cli: find your user, resolve manager ID, write config."""

import json
import os
import subprocess
import sys

CONFIG_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), "config.json")


def sf_query(soql, org=None):
    """Run a SOQL query via sf CLI."""
    cmd = ["sf", "data", "query", "--query", soql, "--json"]
    if org:
        cmd += ["--target-org", org]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        return None
    data = json.loads(result.stdout)
    records = data.get("result", {}).get("records", [])
    return records


def list_authed_orgs():
    """Return list of authenticated org usernames from sf org list."""
    result = subprocess.run(
        ["sf", "org", "list", "--json"],
        capture_output=True, text=True)
    if result.returncode != 0:
        return []
    try:
        data = json.loads(result.stdout)
        orgs = data.get("result", {})
        all_orgs = orgs.get("nonScratchOrgs", []) + orgs.get("scratchOrgs", [])
        return [o.get("username") for o in all_orgs if o.get("username")]
    except (json.JSONDecodeError, AttributeError):
        return []


def pick_org(orgs, existing_org):
    """Let user pick from authenticated orgs, defaulting to the existing one."""
    if not orgs:
        return None
    if len(orgs) == 1:
        return orgs[0]
    default = existing_org if existing_org in orgs else orgs[0]
    print(f"\n  Authenticated orgs:")
    for i, org in enumerate(orgs):
        marker = " (current)" if org == default else ""
        print(f"    {i + 1}. {org}{marker}")
    choice = input(f"\n  Select org [1-{len(orgs)}] (Enter for {default}): ").strip()
    if not choice:
        return default
    try:
        return orgs[int(choice) - 1]
    except (ValueError, IndexError):
        print("  Invalid selection, using default.")
        return default


def check_dependencies():
    """Check that required tools and packages are installed."""
    ok = True

    result = subprocess.run(["which", "sf"], capture_output=True, text=True)
    if result.returncode != 0:
        print("  ✗ sf CLI not found. Install it: https://developer.salesforce.com/tools/salesforcecli")
        ok = False
    else:
        print("  ✓ sf CLI found")

    result = subprocess.run(["which", "fzf"], capture_output=True, text=True)
    if result.returncode != 0:
        print("  ✗ fzf not found. Install it: brew install fzf")
        ok = False
    else:
        print("  ✓ fzf found")

    try:
        import yaml  # noqa: F401
        print("  ✓ pyyaml found")
    except ImportError:
        print("  ✗ pyyaml not found. Install it: pip install pyyaml")
        ok = False

    if not ok:
        print("\n  Please install the missing dependencies and re-run setup.")
        sys.exit(1)


def sf_login():
    """Run sf org login web to authenticate."""
    print("  Opening browser for Salesforce login...\n")
    result = subprocess.run(["sf", "org", "login", "web"])
    if result.returncode != 0:
        print("\n  Login failed. Please try again.")
        sys.exit(1)
    print()


def main():
    print("\n  sf-cli setup\n")

    # Step 0: Check all dependencies
    check_dependencies()
    print()

    # Step 1: Authenticate with Salesforce
    existing = {}
    if os.path.exists(CONFIG_PATH):
        with open(CONFIG_PATH) as f:
            existing = json.load(f)

    existing_org = existing.get("org", "")
    authed_orgs = list_authed_orgs()

    if authed_orgs:
        print(f"  Found {len(authed_orgs)} authenticated org(s).")
        login = input("  Log in to a different org? [y/N]: ").strip().lower()
        if login in ("y", "yes"):
            sf_login()
            authed_orgs = list_authed_orgs()
    else:
        print("  No authenticated orgs found. Opening Salesforce login...")
        sf_login()
        authed_orgs = list_authed_orgs()

    if not authed_orgs:
        print("  Login succeeded but no orgs detected. Run: sf org list")
        sys.exit(1)

    # Step 2: Pick org
    org = pick_org(authed_orgs, existing_org)
    if not org:
        print("  No org selected.")
        sys.exit(1)
    print(f"  Using org: {org}")

    # Step 3: Find the user
    print(f"\n  Searching for your user in {org}...")
    name_search = input("  Your name (or part of it): ").strip()
    if not name_search:
        print("  No name provided.")
        sys.exit(1)

    records = sf_query(
        f"SELECT Id, Name, ManagerId, Manager.Name, Email "
        f"FROM User WHERE Name LIKE '%{name_search}%' AND IsActive = true",
        org=org)

    if not records:
        print("  No users found.")
        sys.exit(1)

    # Filter out attributes
    users = []
    for r in records:
        user = {
            "Id": r.get("Id"),
            "Name": r.get("Name"),
            "Email": r.get("Email"),
            "ManagerId": r.get("ManagerId"),
            "ManagerName": (r.get("Manager") or {}).get("Name", ""),
        }
        users.append(user)

    # If multiple matches, let user pick
    if len(users) > 1:
        print(f"\n  Found {len(users)} users:\n")
        for i, u in enumerate(users):
            print(f"    {i + 1}. {u['Name']} ({u['Email']})")
        choice = input(f"\n  Select [1-{len(users)}]: ").strip()
        try:
            user = users[int(choice) - 1]
        except (ValueError, IndexError):
            print("  Invalid selection.")
            sys.exit(1)
    else:
        user = users[0]

    print(f"\n  User: {user['Name']} ({user['Email']})")
    print(f"  Manager: {user['ManagerName']}")
    print(f"  Manager ID: {user['ManagerId']}")

    # Step 3: Ask if they are a manager (use own ID) or IC (use manager's ID)
    print(f"\n  If you manage a team, your own ID will be used to scope pipeline")
    print(f"  queries. Otherwise, your manager's ID is used.\n")
    is_manager = input("  Are you a manager with direct reports? [y/N]: ").strip().lower()

    if is_manager in ("y", "yes"):
        manager_id = user["Id"]
        print(f"\n  Using your ID: {manager_id}")
    else:
        manager_id = user["ManagerId"]
        print(f"\n  Using your manager's ID: {manager_id}")

    # Step 4: Write config — preserve any existing custom keys, update identity fields
    config = existing.copy()
    config.update({
        "org": org,
        "manager_id": manager_id,
        "user_id": user["Id"],
        "user_name": user["Name"],
    })

    # Set defaults for keys that must be present (never overwrite if already set)
    config.setdefault("deal_types", ["New Business", "Up-sell and Retention"])
    config.setdefault("note_statuses", ["Active", "Inactive"])
    config.setdefault("note_activities", [
        "Disco", "Demo (POM)", "PoC (POM)", "Agents Demo", "Agents Setup",
        "Agents Readout", "RFP", "Value Case", "Closing Support",
        "Handover", "Not Started", "Stalled", "<empty>",
    ])

    with open(CONFIG_PATH, "w") as f:
        json.dump(config, f, indent=2)

    print(f"\n  Config saved to {CONFIG_PATH}")
    print(f"  You're all set!\n")


if __name__ == "__main__":
    main()
