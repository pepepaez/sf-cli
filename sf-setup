#!/usr/bin/env python3
"""Initial setup for sf-cli: install dependencies, authenticate, write config and views."""

import json
import os
import shutil
import subprocess
import sys

SCRIPT_DIR  = os.path.dirname(os.path.abspath(__file__))
CONFIG_PATH = os.path.join(SCRIPT_DIR, "config.json")
VIEWS_PATH  = os.path.join(SCRIPT_DIR, "views.yaml")
VIEWS_EXAMPLE_PATH = os.path.join(SCRIPT_DIR, "views.yaml.example")


# ---------------------------------------------------------------------------
# Dependency helpers
# ---------------------------------------------------------------------------

def _brew_available():
    return subprocess.run(["which", "brew"], capture_output=True).returncode == 0


def _ensure_brew_package(brew_package, bin_name=None, optional=False):
    """Check if a CLI tool is installed; offer to install via Homebrew if not.

    Returns True if the tool is available after this call, False otherwise.
    """
    cmd = bin_name or brew_package
    if subprocess.run(["which", cmd], capture_output=True).returncode == 0:
        print(f"  ✓ {cmd}")
        return True

    label = f"{cmd} (optional)" if optional else cmd
    if not _brew_available():
        print(f"  ✗ {label} — Homebrew not found, install manually or get Homebrew from https://brew.sh")
        return False

    prompt = f"  {label} not found. Install with Homebrew? "
    prompt += "[y/N]: " if optional else "[Y/n]: "
    answer = input(prompt).strip().lower()
    default_yes = not optional
    if (default_yes and answer not in ("n", "no")) or (not default_yes and answer in ("y", "yes")):
        print(f"  Installing {brew_package}...", flush=True)
        result = subprocess.run(["brew", "install", brew_package])
        if result.returncode == 0:
            print(f"  ✓ {cmd} installed")
            return True
        print(f"  ✗ Failed to install {brew_package}. Try manually: brew install {brew_package}")
        return False
    return False


def _ensure_pyyaml():
    """Check if pyyaml is importable; offer to install via pip if not."""
    try:
        import yaml  # noqa: F401
        print("  ✓ pyyaml")
        return True
    except ImportError:
        pass

    answer = input("  pyyaml not found. Install with pip? [Y/n]: ").strip().lower()
    if answer in ("n", "no"):
        print("  pyyaml is required. Install manually: pip3 install --user pyyaml")
        return False

    print("  Installing pyyaml...", flush=True)
    # Try --user first (avoids PEP 668 restriction on managed Pythons)
    result = subprocess.run(
        [sys.executable, "-m", "pip", "install", "--user", "pyyaml"],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        print("  ✓ pyyaml installed")
        return True
    # Fall back to --break-system-packages (Homebrew Python)
    result = subprocess.run(
        [sys.executable, "-m", "pip", "install", "--break-system-packages", "pyyaml"],
        capture_output=True, text=True,
    )
    if result.returncode == 0:
        print("  ✓ pyyaml installed")
        return True
    print("  ✗ Failed to install pyyaml. Try: pip3 install --user pyyaml")
    return False


def check_and_install_dependencies():
    """Check all dependencies; install missing ones interactively. Exits on failure."""
    print("  Checking dependencies...\n")
    sf_ok   = _ensure_brew_package("salesforce-cli", bin_name="sf")
    fzf_ok  = _ensure_brew_package("fzf")
    yaml_ok = _ensure_pyyaml()
    # VisiData is optional — enables the --vd flag
    _ensure_brew_package("visidata", bin_name="vd", optional=True)

    print()
    if not all([sf_ok, fzf_ok, yaml_ok]):
        print("  Required dependencies are missing. Fix the above and re-run setup.")
        sys.exit(1)


# ---------------------------------------------------------------------------
# Salesforce org helpers
# ---------------------------------------------------------------------------

def sf_query(soql, org=None):
    """Run a SOQL query via sf CLI and return list of record dicts."""
    cmd = ["sf", "data", "query", "--query", soql, "--json"]
    if org:
        cmd += ["--target-org", org]
    result = subprocess.run(cmd, capture_output=True, text=True)
    if result.returncode != 0:
        return None
    data = json.loads(result.stdout)
    records = data.get("result", {}).get("records", [])
    return records


def list_authed_orgs():
    """Return list of authenticated org usernames from sf org list."""
    result = subprocess.run(["sf", "org", "list", "--json"], capture_output=True, text=True)
    if result.returncode != 0:
        return []
    try:
        data = json.loads(result.stdout)
        orgs = data.get("result", {})
        all_orgs = orgs.get("nonScratchOrgs", []) + orgs.get("scratchOrgs", [])
        return [o.get("username") for o in all_orgs if o.get("username")]
    except (json.JSONDecodeError, AttributeError):
        return []


def sf_login():
    """Run sf org login web to authenticate."""
    print("  Opening browser for Salesforce login...\n")
    result = subprocess.run(["sf", "org", "login", "web"])
    if result.returncode != 0:
        print("\n  Login failed. Please try again.")
        sys.exit(1)
    print()


def pick_org(orgs, existing_org):
    """Let user pick from authenticated orgs, defaulting to the existing one."""
    if len(orgs) == 1:
        return orgs[0]
    default = existing_org if existing_org in orgs else orgs[0]
    print("  Authenticated orgs:")
    for i, org in enumerate(orgs):
        marker = "  ← current" if org == default else ""
        print(f"    {i + 1}. {org}{marker}")
    choice = input(f"\n  Select org [1-{len(orgs)}] (Enter for {default}): ").strip()
    if not choice:
        return default
    try:
        return orgs[int(choice) - 1]
    except (ValueError, IndexError):
        print("  Invalid selection, using default.")
        return default


# ---------------------------------------------------------------------------
# Views setup
# ---------------------------------------------------------------------------

def create_views_if_missing():
    """Copy views.yaml.example → views.yaml if no views file exists yet."""
    if os.path.exists(VIEWS_PATH):
        return
    if not os.path.exists(VIEWS_EXAMPLE_PATH):
        print("  ⚠ views.yaml.example not found — skipping views setup")
        return
    shutil.copy(VIEWS_EXAMPLE_PATH, VIEWS_PATH)
    print(f"  Created views.yaml from template — edit it to customise your saved views")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    print("\n  sf-cli setup\n")

    # Step 1: Dependencies
    check_and_install_dependencies()

    # Step 2: Salesforce authentication
    existing = {}
    if os.path.exists(CONFIG_PATH):
        with open(CONFIG_PATH) as f:
            existing = json.load(f)

    existing_org = existing.get("org", "")
    authed_orgs = list_authed_orgs()

    if authed_orgs:
        print(f"  Found {len(authed_orgs)} authenticated org(s).")
        if input("  Log in to a different org? [y/N]: ").strip().lower() in ("y", "yes"):
            sf_login()
            authed_orgs = list_authed_orgs()
    else:
        print("  No authenticated orgs found. Opening Salesforce login...")
        sf_login()
        authed_orgs = list_authed_orgs()

    if not authed_orgs:
        print("  Login succeeded but no orgs detected. Run: sf org list")
        sys.exit(1)

    print()
    org = pick_org(authed_orgs, existing_org)
    print(f"\n  Using org: {org}")

    # Step 3: Find the user in Salesforce
    print(f"\n  Searching for your user in {org}...")
    name_search = input("  Your name (or part of it): ").strip()
    if not name_search:
        print("  No name provided.")
        sys.exit(1)

    records = sf_query(
        f"SELECT Id, Name, ManagerId, Manager.Name, Email "
        f"FROM User WHERE Name LIKE '%{name_search}%' AND IsActive = true",
        org=org,
    )
    if not records:
        print("  No users found.")
        sys.exit(1)

    users = [
        {
            "Id":          r.get("Id"),
            "Name":        r.get("Name"),
            "Email":       r.get("Email"),
            "ManagerId":   r.get("ManagerId"),
            "ManagerName": (r.get("Manager") or {}).get("Name", ""),
        }
        for r in records
    ]

    if len(users) > 1:
        print(f"\n  Found {len(users)} users:\n")
        for i, u in enumerate(users):
            print(f"    {i + 1}. {u['Name']} ({u['Email']})")
        choice = input(f"\n  Select [1-{len(users)}]: ").strip()
        try:
            user = users[int(choice) - 1]
        except (ValueError, IndexError):
            print("  Invalid selection.")
            sys.exit(1)
    else:
        user = users[0]

    print(f"\n  User:    {user['Name']} ({user['Email']})")
    print(f"  Manager: {user['ManagerName']}")

    # Step 4: Determine manager_id scoping
    print(f"\n  Pipeline queries are scoped by a manager ID.")
    print(f"  Use your own ID if you manage the team; your manager's ID if you're an IC.\n")
    if input("  Are you a manager with direct reports? [y/N]: ").strip().lower() in ("y", "yes"):
        manager_id = user["Id"]
        print(f"\n  Using your ID: {manager_id}")
    else:
        manager_id = user["ManagerId"]
        print(f"\n  Using your manager's ID: {manager_id}")

    # Step 5: Write config
    config = existing.copy()
    config.update({
        "org":        org,
        "manager_id": manager_id,
        "user_id":    user["Id"],
        "user_name":  user["Name"],
    })
    config.setdefault("deal_types", ["New Business", "Up-sell and Retention"])
    config.setdefault("note_statuses", ["Active", "Inactive"])
    config.setdefault("note_activities", [
        "Disco", "Demo (POM)", "PoC (POM)", "Agents Demo", "Agents Setup",
        "Agents Readout", "RFP", "Value Case", "Closing Support",
        "Handover", "Not Started", "Stalled", "<empty>",
    ])

    with open(CONFIG_PATH, "w") as f:
        json.dump(config, f, indent=2)
    print(f"\n  Config saved → config.json")

    # Step 6: Create views.yaml if this is a fresh install
    create_views_if_missing()

    print(f"\n  You're all set! Run: salesfx --team\n")


if __name__ == "__main__":
    main()
