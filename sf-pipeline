#!/usr/bin/env python3
"""Interactive pipeline explorer with drill-down navigation."""

import argparse
import json
import os
import re
import subprocess
import sys
import tempfile
from collections import defaultdict

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import sfq
from shared import (
    BOLD, CYAN, DIM, GREEN, RESET,
    AGG_DIMENSIONS, DEFAULT_DIMS, DEFAULT_MANAGER_ID, DEAL_TYPES,
    LIST_FIELD_MAP, QUARTER_HELP,
    build_quarter_clause, c, dump_output, enrich, fmt_eur,
    format_table_lines, opp_list_view, remap_type, to_float,
)

OPP_QUERY = """
SELECT Account.Name, Name, Id, convertCurrency(Amount), CurrencyIsoCode,
       Territory__c, Owner.Name, CloseDate, StageName, Type,
       Solution_Strategist1__r.Name, Supporting_Solution_Strategist__r.Name,
       Managerial_Forecast_Category__c, Competitor__c, Compelling_Event__c,
       NextStep, CreatedDate, LastStageChangeDate, Description
FROM Opportunity
WHERE IsClosed = false
  AND (Solution_Strategist1__r.ManagerId = '{manager_id}'
       OR Solution_Strategist1__r.Id = '{manager_id}')
  AND {quarter_clause}
ORDER BY CloseDate ASC
""".strip()


def fetch_opps(manager_id, quarter_clause):
    query = OPP_QUERY.format(manager_id=manager_id, quarter_clause=quarter_clause)
    records = sfq.sf_query(query)
    records = [r for r in records if r.get("Type", "") in DEAL_TYPES]
    return enrich(records)


def aggregate_report(records, dim_keys):
    groups = defaultdict(lambda: {"acv": 0.0, "count": 0, "opps": []})
    for r in records:
        key = tuple(r[AGG_DIMENSIONS[dk][0]] for dk in dim_keys)
        groups[key]["acv"] += r["_acv"]
        groups[key]["count"] += 1
        groups[key]["opps"].append(r)

    rows = []
    for key in sorted(groups.keys()):
        g = groups[key]
        row = {"_opps": g["opps"]}
        for i, dk in enumerate(dim_keys):
            row[dk] = key[i]
        row["acv"] = fmt_eur(g["acv"])
        row["count"] = str(g["count"])
        rows.append(row)
    return rows


def level_0(records):
    """Aggregated report with configurable dimensions."""
    script_dir = os.path.dirname(os.path.abspath(__file__))
    preview_script = os.path.join(script_dir, "fzf-preview-pipeline.py")
    dims = list(DEFAULT_DIMS)

    while True:
        agg_rows = aggregate_report(records, dims)
        total_acv = sum(r["_acv"] for r in records)

        if not agg_rows:
            print("No records found.")
            return

        field_map = {}
        for dk in dims:
            field_map[dk] = AGG_DIMENSIONS[dk][1]
        field_map["acv"] = "ACV"
        field_map["count"] = "#"

        # Group leading dimension columns (all except acv and count)
        group_cols = len(dims) - 1 if len(dims) > 1 else 0
        header, sep, lines = format_table_lines(agg_rows, field_map, group_cols=group_cols)

        # Write opps per row to temp file for preview
        preview_data = []
        for row in agg_rows:
            opps = row["_opps"]
            preview_data.append([
                {k: v for k, v in r.items() if not k.startswith("_")}
                for r in opps
            ])
        tmp = tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False)
        json.dump(preview_data, tmp)
        tmp.close()

        try:
            all_dim_keys = list(AGG_DIMENSIONS.keys())
            dim_toggles = []
            for dk in all_dim_keys:
                label = AGG_DIMENSIONS[dk][1]
                if dk in dims:
                    dim_toggles.append(f"  \033[32mON \033[0m  {label}")
                else:
                    dim_toggles.append(f"  \033[2mOFF\033[0m  {label}")

            # Prefix toggles and data lines with tab-separated index
            TAB = "\t"
            numbered_toggles = [f"T{i:03d}{TAB}{t}" for i, t in enumerate(dim_toggles)]
            numbered_lines = [f"D{i:03d}{TAB}{line}" for i, line in enumerate(lines)]

            sep_line = f"{'─' * 40}"
            col_header = f"____{TAB}{header}"
            col_sep = f"____{TAB}{sep}"

            fzf_items = numbered_toggles + [f"____{TAB}{sep_line}", col_header, col_sep] + numbered_lines
            help_line = (f"\033[2mESC\033[0m back  "
                         f"\033[2mEnter\033[0m toggle/drill-down  "
                         f"\033[2m←/→\033[0m scroll preview  "
                         f"\033[2mctrl-/\033[0m resize pane")
            fzf_header = (f"{help_line}\n"
                          f"\033[1m\033[36mTotal: {fmt_eur(total_acv)}\033[0m  |  {len(records)} opps")

            dims_arg = ",".join(dims)
            preview_cmd = f"python3 {preview_script} {tmp.name} {{1}} {dims_arg}"
            cmd = ["fzf", "--prompt", "Pipeline > ", "--height", "90%", "--reverse",
                   "--no-sort", "--ansi", "--delimiter", "\t", "--with-nth", "2..",
                   "--preview", preview_cmd, "--preview-window", "right:50%:wrap",
                   "--bind", "right:preview-down",
                   "--bind", "left:preview-up",
                   "--bind", "ctrl-/:change-preview-window(right,70%,wrap|right,50%,wrap|right,30%,wrap|hidden)"]
            result = subprocess.run(cmd + ["--header", fzf_header],
                                    input="\n".join(fzf_items),
                                    capture_output=True, text=True)
        finally:
            os.unlink(tmp.name)

        if result.returncode != 0:
            return

        selected = result.stdout.strip()
        prefix = selected.split(TAB, 1)[0] if selected else ""

        if prefix.startswith("T"):
            try:
                tidx = int(prefix[1:])
                dk = all_dim_keys[tidx]
                if dk in dims:
                    if len(dims) > 1:
                        dims.remove(dk)
                else:
                    dims.append(dk)
            except (ValueError, IndexError):
                pass
            continue

        if prefix.startswith("D"):
            try:
                idx = int(prefix[1:])
                context = lines[idx].rstrip()
                opp_list_view(agg_rows[idx]["_opps"], context)
            except (ValueError, IndexError):
                pass
            continue


def main():
    parser = argparse.ArgumentParser(description="Interactive pipeline explorer")
    parser.add_argument("-q", "--quarter", metavar="QUARTER", default="this+next",
                        help=f"{QUARTER_HELP}")
    parser.add_argument("-o", "--output", metavar="OUTPUT",
                        help="Non-interactive output: vd, console, or filename.csv")
    parser.add_argument("--team", metavar="MANAGER_ID", default=DEFAULT_MANAGER_ID,
                        help="Manager ID (default: yours)")
    args = parser.parse_args()

    quarter_clause = build_quarter_clause(args.quarter)
    records = fetch_opps(args.team, quarter_clause)

    if not records:
        print("No open opportunities found.")
        return

    if args.output:
        dump_output(records, args.output)
    else:
        level_0(records)


if __name__ == "__main__":
    main()
