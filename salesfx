#!/usr/bin/env python3
"""Search and browse opportunities with flexible filters."""

import argparse
import json
import os
import sys
from datetime import datetime

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import sfq
from shared import (
    BOLD, DIM, GREEN, RESET, YELLOW,
    CACHE_DIR, OPP_CACHE_FILE,
    DEAL_TYPES, DEFAULT_MANAGER_ID, LIST_FIELD_MAP,
    QUARTER_HELP, STAGE_PRESET_HELP,
    apply_filters, build_filter_summary, make_filter_parser,
    dump_output, enrich, escape_soql, inject_notes, load_latest_notes,
    fmt_eur, fzf, format_table_lines, grouped_view, opp_list_view,
    load_views, view_to_args_str,
    remap_type, to_float,
)

OPP_FIELDS = (
    "Account.Name, Name, Id, convertCurrency(Amount), CurrencyIsoCode, "
    "Territory__c, Owner.Name, CloseDate, StageName, Type, IsClosed, "
    "Solution_Strategist1__r.Name, Solution_Strategist1__r.ManagerId, "
    "Solution_Strategist1__r.Id, Supporting_Solution_Strategist__r.Name, "
    "Managerial_Forecast_Category__c, Competitor__c, Compelling_Event__c, "
    "NextStep, CreatedDate, LastStageChangeDate, Description"
)


def build_cache_query():
    """Broad SOQL query covering prev/current/next year — all filters applied in Python."""
    year = datetime.now().year
    return (
        f"SELECT {OPP_FIELDS} FROM Opportunity "
        f"WHERE CloseDate >= {year - 1}-01-01 AND CloseDate <= {year + 1}-12-31 "
        "ORDER BY Account.Name, CloseDate ASC"
    )





def pick_view(views):
    """Present views in fzf and return the selected view name, or None."""
    import subprocess
    if not views:
        return None
    name_width = max(len(n) for n in views)
    lines = [f"{name:<{name_width}}  {view_to_args_str(cfg)}"
             for name, cfg in views.items()]
    result = subprocess.run(
        ["fzf", "--prompt", "View > ", "--height", "40%", "--reverse",
         "--ansi", "--no-sort", "--header", "Select a view (Enter to launch)"],
        input="\n".join(lines), capture_output=True, text=True,
    )
    if result.returncode != 0 or not result.stdout.strip():
        return None
    return result.stdout.strip().split()[0]


def apply_view(args, view):
    """Apply a saved view's settings to args (CLI flags take precedence)."""
    # Fields that argparse nargs="+" always stores as lists
    list_fields = {"type", "stage", "territory", "quarter"}
    for key, val in view.items():
        if key == "team" and val is True:
            if args.team is None:
                args.team = DEFAULT_MANAGER_ID
        elif not getattr(args, key, None):
            # Wrap single strings in a list for nargs="+" fields
            if key in list_fields and isinstance(val, str):
                val = [val]
            setattr(args, key, val)


def main():
    parser = argparse.ArgumentParser(
        description="Search and browse opportunities with filters")
    parser.add_argument("--view", "-v", metavar="NAME",
                        help="Use a saved view from views.yaml")
    parser.add_argument("--account", "-a", metavar="NAME",
                        help="Filter by account name (fuzzy)")
    parser.add_argument("--ae", metavar="NAME",
                        help="Filter by opportunity owner / AE (fuzzy)")
    parser.add_argument("--ninja", "-n", metavar="NAME",
                        help="Filter by Solution Strategist (fuzzy)")
    parser.add_argument("--quarter", "-q", nargs="+", metavar="QUARTER",
                        help=f"Filter by quarter: {QUARTER_HELP}")
    parser.add_argument("--type", "-t", nargs="+", metavar="TYPE",
                        help="Filter by deal type(s) (e.g. 'New Business' or multiple)")
    parser.add_argument("--stage", "-s", nargs="+", metavar="STAGE",
                        help=f"Filter by stage(s) or preset: {STAGE_PRESET_HELP}")
    parser.add_argument("--team", nargs="?", const=DEFAULT_MANAGER_ID, default=None,
                        metavar="MANAGER_ID",
                        help="Filter by team (default: your ID from config)")
    parser.add_argument("--territory", "-r", nargs="+", metavar="TERRITORY",
                        help="Filter by territory")
    parser.add_argument("--all-stages", "-A", action="store_true",
                        help="Include closed/won opportunities (all stages)")
    parser.add_argument("--refresh", action="store_true",
                        help="Re-fetch data from Salesforce and update local cache")
    parser.add_argument("--vd", action="store_true",
                        help="Open results in VisiData")
    parser.add_argument("--out", metavar="FILE",
                        help="Save results to CSV file")
    args = parser.parse_args()

    # Apply saved view if specified
    active_view = {}
    if args.view:
        views = load_views()
        if args.view == "ls":
            selected = pick_view(views)
            if not selected:
                sys.exit(0)
            args.view = selected
        if args.view not in views:
            available = ", ".join(views.keys()) if views else "(none)"
            print(f"  Unknown view: {args.view}")
            print(f"  Available: {available}")
            sys.exit(1)
        active_view = views[args.view]
        apply_view(args, active_view)

    # --team implies default quarter if not specified
    if args.team and not args.quarter:
        args.quarter = ["this+next"]

    has_filter = any([args.account, args.ae, args.ninja, args.quarter,
                      args.type, args.stage, args.team, args.territory])
    if not has_filter and not args.refresh:
        parser.print_help()
        sys.exit(0)
    if args.refresh and not has_filter:
        # Refresh-only: update cache and exit
        print("\033[2J\033[H", end="")
        print(f"\n  {BOLD}{YELLOW}Fetching from Salesforce...{RESET}\n")
        query = build_cache_query()
        records = sfq.sf_query(query)
        os.makedirs(CACHE_DIR, exist_ok=True)
        fetched_at = datetime.now().strftime("%Y-%m-%d %H:%M")
        with open(OPP_CACHE_FILE, "w") as f:
            json.dump({"fetched_at": fetched_at, "records": records}, f)
        print(f"  {GREEN}Cache updated — {len(records)} records ({fetched_at}){RESET}\n")
        sys.exit(0)

    print("\033[2J\033[H", end="")
    filter_summary = build_filter_summary(args)

    # Load from cache or refresh from SF
    use_cache = not args.refresh and os.path.exists(OPP_CACHE_FILE)
    if use_cache:
        with open(OPP_CACHE_FILE) as f:
            cache_data = json.load(f)
        records = cache_data["records"]
        fetched_at = cache_data.get("fetched_at", "")
        cache_label = f"cache from {fetched_at}"
        print(f"\n  {DIM}Using local cache ({fetched_at}) — run with --refresh to update{RESET}\n")
    else:
        print(f"\n  {BOLD}{YELLOW}Fetching from Salesforce...{RESET} ({filter_summary})\n")
        query = build_cache_query()
        records = sfq.sf_query(query)
        os.makedirs(CACHE_DIR, exist_ok=True)
        fetched_at = datetime.now().strftime("%Y-%m-%d %H:%M")
        with open(OPP_CACHE_FILE, "w") as f:
            json.dump({"fetched_at": fetched_at, "records": records}, f)
        cache_label = f"refreshed {fetched_at}"

    # Apply Python-side user filters
    all_records = records
    records = apply_filters(all_records, args)

    # OR-in extra ninjas from the view (e.g. former team members), same stage/quarter rules
    include_ninjas = active_view.get("include_ninjas", [])
    if include_ninjas:
        seen_ids = {r["Id"] for r in records}
        no_team_vars = {**vars(args), "team": None}
        pool = apply_filters(all_records, argparse.Namespace(**no_team_vars))
        for name in include_ninjas:
            q = name.lower()
            for r in pool:
                if r["Id"] not in seen_ids and q in (r.get("Solution_Strategist1__r.Name", "") or "").lower():
                    records.append(r)
                    seen_ids.add(r["Id"])

    # Apply deal types filter before enrich (which remaps type names)
    if DEAL_TYPES:
        records = [r for r in records if r.get("Type", "") in DEAL_TYPES]

    records = enrich(records)

    print(f"\033[2A\033[K  {len(records)} opportunities ({filter_summary}) · {cache_label}\n")

    if not records:
        return

    # Non-interactive outputs
    if args.vd or args.out:
        inject_notes(records, load_latest_notes())
        if args.vd:
            dump_output(records, "vd")
        else:
            dump_output(records, args.out)
        return

    # Build filters dict for saving views
    filters = {}
    if args.team:
        filters["team"] = True if args.team == DEFAULT_MANAGER_ID else args.team
    if args.account:
        filters["account"] = args.account
    if args.ae:
        filters["ae"] = args.ae
    if args.ninja:
        filters["ninja"] = args.ninja
    if args.quarter:
        filters["quarter"] = args.quarter
    if args.type:
        filters["type"] = args.type if len(args.type) > 1 else args.type[0]
    if args.stage:
        filters["stage"] = args.stage if len(args.stage) > 1 else args.stage[0]
    if args.territory:
        filters["territory"] = args.territory

    # Interactive: always start in flat list, ctrl-g to toggle grouped view
    opp_list_view(records, filter_summary, filters=filters)


if __name__ == "__main__":
    main()
