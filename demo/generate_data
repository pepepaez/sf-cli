    }
    with open(os.path.join(DEMO_DIR, "config.json"), "w") as f:
        json.dump(config, f, indent=2)
    print("  ✓ config.json")

    # opps cache
    fetched_at = datetime.now().strftime("%Y-%m-%d %H:%M")
    cache = {"fetched_at": fetched_at, "records": OPPS}
    with open(os.path.join(CACHE_DIR, "opps.json"), "w") as f:
        json.dump(cache, f, indent=2)
    print(f"  ✓ cache/opps.json  ({len(OPPS)} opportunities)")

    # chatter cache
    for opp_id, posts in CHATTER_POSTS.items():
        path = os.path.join(CHATTER_DIR, f"{opp_id}.json")
        with open(path, "w") as f:
            json.dump({"fetched_at": fetched_at, "posts": posts}, f, indent=2)
    print(f"  ✓ cache/chatter/   ({len(CHATTER_POSTS)} files)")

    # notes history
    history = [
        {
            "opp_id":   n["opp_id"],
            "status":   n["status"],
            "activity": n["activity"],
            "date":     n["date"],
            "author":   n["author"],
        }
        for n in NOTES
    ]
    with open(os.path.join(DEMO_DIR, "notes_history.json"), "w") as f:
        json.dump(history, f, indent=2)
    print(f"  ✓ notes_history.json  ({len(history)} notes)")

    print(f"\n  Done. Run:  demo/salesfx --team\n")


if __name__ == "__main__":
    main()
